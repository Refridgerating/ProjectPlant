[Unit]
Description=ProjectPlant Hub API and Dashboard
After=network-online.target mosquitto.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/projectplant/current/apps/hub/src
EnvironmentFile=-/etc/projectplant/hub.env
Environment=PROJECTPLANT_UI_DIST=/opt/projectplant/current/apps/ui/dist
ExecStart=/usr/bin/env python3 -m uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
